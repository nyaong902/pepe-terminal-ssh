{
  "name": "pepe-terminal-ssh",
  "productName": "PePe Terminal(SSH)",
  "private": true,
  "version": "2.0.4",
  "description": "SSH Terminal Client",
  "author": "Claude (feat. ghjeong[prompt])",
  "type": "commonjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && node -e \"require('fs').copyFileSync('electron/mcpSshServer.cjs','dist-electron/mcpSshServer.cjs')\" && electron-builder",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "iconv-lite": "^0.6.3",
    "marked": "^18.0.2",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ssh2": "^1.11.0",
    "webdav-server": "^2.6.2",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-search": "^0.13.0",
    "xterm-addon-unicode11": "^0.6.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "typescript": "^5.2.2",
    "vite": "^5.4.21",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "main": "dist-electron/main.js",
  "build": {
    "appId": "com.ghjeong.pepe-terminal-ssh",
    "productName": "PePe Terminal(SSH)",
    "extraMetadata": {
      "name": "PePe Terminal(SSH)"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/node-pty/**/*"
    ],
    "asarUnpack": [
      "dist-electron/mcpSshServer.cjs"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/icon.ico",
      "signingHashAlgorithms": [
        "sha256"
      ],
      "certificateFile": "cert/PePeTerminal_v2.pfx",
      "certificatePassword": "pepe1234"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh",
      "shortcutName": "PePe Terminal(SSH)"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "public/icon-mac.png",
      "category": "public.app-category.developer-tools",
      "identity": null,
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  }
}
